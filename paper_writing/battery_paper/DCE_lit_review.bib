@article{byunUsingDiscreteChoice2018,
  title = {Using a Discrete Choice Experiment to Predict the Penetration Possibility of Environmentally Friendly Vehicles},
  author = {Byun, Hyunsuk and Shin, Jungwoo and Lee, Chul-Yong},
  date = {2018-02-01},
  journaltitle = {Energy},
  shortjournal = {Energy},
  volume = {144},
