@article{hagmanTotalCostOwnership2016a,
  title = {Total Cost of Ownership and Its Potential Implications for Battery Electric Vehicle Diffusion},
  author = {Hagman, Jens and Ritzén, Sofia and Stier, Jenny Janhager and Susilo, Yusak},
