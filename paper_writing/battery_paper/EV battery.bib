@article{jiaoBusinessModelsSustainability2016,
  title = {Business {{Models}} for {{Sustainability}}: {{The Case}} of {{Second-life Electric Vehicle Batteries}}},
  shorttitle = {Business {{Models}} for {{Sustainability}}},
  author = {Jiao, Na and Evans, Steve},
